{
  "name": "@effect-zero/test-utils",
  "version": "0.0.0",
  "private": true,
  "description": "Shared test utilities, API fixtures, and database helpers for effect-zero packages.",
  "license": "MIT",
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./api-fixtures": "./src/api-fixtures.ts",
    "./postgres-test-db": "./src/postgres-test-db.ts",
