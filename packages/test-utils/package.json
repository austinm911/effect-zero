  "dependencies": {
    "@effect-zero/example-data": "workspace:*",
    "@rocicorp/zero": "catalog:",
    "pg": "8.20.0"
  },
  "devDependencies": {
    "@effect-zero/tsconfig": "workspace:*",
    "@types/node": "^25.3.5",
    "@types/pg": "^8.15.5",
    "typescript": "^5.9.3",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}
