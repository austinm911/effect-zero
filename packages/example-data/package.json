{
  "name": "@effect-zero/example-data",
  "version": "0.0.0",
  "private": true,
  "description": "Shared example schema and mutators for the music-store fixture.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./db": "./src/db/schema.ts",
    "./queries": "./src/queries.ts",
    "./zero": "./src/zero/schema.ts",
    "./mutators": "./src/mutators.ts",
    "./mutators/context": "./src/mutators/context.ts",
    "./server-fixture": "./src/server-fixture.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "db:generate": "pnpm exec drizzle-kit generate",
    "db:migrate": "pnpm exec drizzle-kit migrate",
    "db:push": "pnpm exec drizzle-kit push",
    "dev": "vp pack --watch",
    "generate:zero-schema": "pnpm exec drizzle-zero generate --force -o src/zero/schema.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "vp pack"
  },
  "dependencies": {
    "@rocicorp/zero": "catalog:",
    "drizzle-orm": "catalog:",
    "postgres": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@effect-zero/tsconfig": "workspace:*",
    "@types/node": "^25.3.5",
    "@typescript/native-preview": "7.0.0-dev.20260309.1",
    "bumpp": "^10.4.1",
    "drizzle-kit": "catalog:",
    "drizzle-zero": "catalog:",
    "tsdown": "catalog:",
    "typescript": "^5.9.3",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}
