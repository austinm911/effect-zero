{
  "name": "effect-zero",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "bench:api": "pnpm exec tsx benchmarks/run-api-benchmarks.mjs",
    "bench:api:quick": "pnpm exec tsx benchmarks/run-api-benchmarks.mjs --samples 1",
    "build": "vp run build -r",
    "check": "vp fmt . --check && vp lint",
    "dev": "vp run --workspace-root stack:web",
    "dev:api": "vp run --workspace-root stack:api",
    "dev:db": "pnpm --filter @effect-zero/alchemy dev && pnpm --filter @effect-zero/example-data db:push",
    "dev:stack": "vp run --workspace-root stack:dev",
    "dev:zero": "vp run --workspace-root stack:zero",
    "desloppify:setup": "node tools/desloppify-setup.mjs",
    "desloppify:scan": "pnpm desloppify:setup && desloppify scan --path .",
    "desloppify:status": "desloppify status",
    "desloppify:queue": "node tools/desloppify-queue.mjs",
    "fmt:fix": "vp fmt . --write",
    "ready": "pnpm check && vp run test -r && vp run build -r",
    "release:check": "pnpm ready && vp run verify:client-entrypoints",
    "release:version": "node tools/release-package.mjs",
    "seed:ztunes": "node tools/load-ztunes-seed.mjs",
    "publish:package": "node tools/publish-package.mjs",
    "publish:v3": "node tools/publish-package.mjs packages/effect-zero-v3",
    "publish:v4": "node tools/publish-package.mjs packages/effect-zero-v4",
    "publish:v4:beta": "node tools/publish-package.mjs packages/effect-zero-v4 --tag beta",
    "test": "vp run test -r",
    "verify:client-entrypoints": "node tools/check-client-entrypoints.mjs",
    "verify:api": "pnpm exec tsx tools/verify-api-targets.mjs",
    "verify:api:package": "VERIFY_API_BASE_URL=http://localhost:4311 pnpm exec tsx tools/verify-api-targets.mjs --target control,v3-drizzle,v3-pg,v3-postgresjs,v4-drizzle,v4-pg,v4-postgresjs",
    "verify:mutation-stress": "pnpm exec tsx tools/verify-mutation-stress.mjs",
    "verify:mutation-stress:package": "VERIFY_API_BASE_URL=http://localhost:4311 pnpm exec tsx tools/verify-mutation-stress.mjs --target control,v3-drizzle,v3-pg,v3-postgresjs,v4-drizzle,v4-pg,v4-postgresjs"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "catalog:",
    "@cloudflare/workers-types": "catalog:",
    "@effect-zero/tsconfig": "workspace:*",
    "tsx": "^4.20.5",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.32.1"
}
